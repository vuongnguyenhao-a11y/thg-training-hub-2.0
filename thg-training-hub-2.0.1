    .update-item p  { font-size: 12px; color: var(--gray-600); line-height: 1.5; }

    /* ── ANNOUNCEMENT ── */
    .note-box { border-radius: 10px; padding: 14px 18px; display: flex; gap: 12px; align-items: flex-start; margin-bottom: 16px; }
    .note-box.info  { background: var(--blue-light); border-left: 4px solid var(--blue); }
    .note-box.warn  { background: var(--yellow-bg);  border-left: 4px solid var(--yellow); }
    .note-box.danger{ background: var(--red-bg);     border-left: 4px solid var(--red); }
    .note-box .nb-icon { font-size: 18px; flex-shrink: 0; margin-top: 1px; }
    .note-box p { font-size: 13px; line-height: 1.6; }
    .note-box.info   p { color: #1e3a8a; }
    .note-box.warn   p { color: #713f12; }
    .note-box.danger p { color: #991b1b; }

    /* ── PROGRESS NAV ── */
    .module-progress-nav { background: #fff; border: 1px solid var(--gray-200); border-radius: 12px; padding: 16px 20px; margin-bottom: 28px; display: flex; gap: 8px; flex-wrap: wrap; align-items: center; }
    .mpn-label { font-size: 12px; font-weight: 600; color: var(--gray-400); margin-right: 4px; }
    .mpn-item { padding: 5px 12px; border-radius: 20px; font-size: 12px; font-weight: 600; cursor: pointer; text-decoration: none; transition: background 0.15s, color 0.15s; border: 1.5px solid var(--gray-200); color: var(--gray-600); background: var(--gray-50); }
    .mpn-item:hover { border-color: var(--orange); color: var(--orange); }
    .mpn-item.done { border-color: var(--green); background: var(--green-bg); color: var(--green); }

    /* ── FOOTER ── */
