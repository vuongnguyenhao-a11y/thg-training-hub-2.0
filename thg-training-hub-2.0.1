    /* ROUTE CARDS */
    .route-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:16px;margin-bottom:20px}
    .route-card{background:#fff;border:1px solid var(--gray-200);border-radius:14px;overflow:hidden}
