    .sop-id-badge.debt {background:var(--red);color:#fff}
    .sop-id-badge.pay  {background:var(--green);color:#fff}
    .sop-header h2{font-size:16px;font-weight:800;color:var(--gray-900)}
    .sop-header p{font-size:12.5px;color:var(--gray-600);margin-top:2px}
    .sop-meta{margin-left:auto;display:flex;flex-direction:column;align-items:flex-end;gap:4px;flex-shrink:0}
    .sop-meta .sm-tag{font-size:11px;font-weight:600;padding:2px 9px;border-radius:12px;background:var(--red-bg);color:var(--red)}
