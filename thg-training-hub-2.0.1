<script>
  function toggleSidebar(){
    document.getElementById('sidebar').classList.toggle('open');
    document.getElementById('overlay').classList.toggle('visible');
  }
  function togglePolicy(header){
    const body=header.nextElementSibling;
    const t=header.querySelector('.toggle');
    body.classList.toggle('open');
    t.style.transform=body.classList.contains('open')?'rotate(180deg)':'';
  }
  const sections=document.querySelectorAll('.content-section');
  const navItems=document.querySelectorAll('.topic-nav-item');
  window.addEventListener('scroll',()=>{
    let cur='';
    sections.forEach(s=>{if(window.scrollY>=s.offsetTop-80)cur=s.id});
    navItems.forEach(i=>i.classList.toggle('current',i.getAttribute('href')==='#'+cur));
  });

  /* ── SIDEBAR DROPDOWN TOGGLE ── */
  (function(){
    var K='thg_nav2',S;
    try{S=JSON.parse(localStorage.getItem(K)||'{}')}catch(e){S={}}
    function sv(k,v){S[k]=v;try{localStorage.setItem(K,JSON.stringify(S))}catch(e){}}
    var sb=document.getElementById('sidebar');
    if(!sb)return;
    // 1. nav-section-label toggles
    sb.querySelectorAll('.nav-section').forEach(function(sec,i){
      var lbl=sec.querySelector('.nav-section-label');
      if(!lbl)return;
      var key='sec'+i;
      var body=document.createElement('div');
      body.className='nav-section-body';
      var kids=[].slice.call(sec.children).filter(function(c){return c!==lbl});
      kids.forEach(function(c){body.appendChild(c)});
      sec.appendChild(body);
      var arr=document.createElement('span');
      arr.className='nav-arrow';arr.textContent='▶';lbl.appendChild(arr);
      var open=S[key]!==undefined?S[key]:true;
      body.style.maxHeight=open?'2000px':'0';
      arr.style.transform=open?'rotate(90deg)':'';
      lbl.addEventListener('click',function(){
        var o=body.style.maxHeight==='0px';
        body.style.maxHeight=o?'2000px':'0';
        arr.style.transform=o?'rotate(90deg)':'';
        sv(key,o);
      });
    });
    // 2. nav-item sub-topic toggles
    sb.querySelectorAll('.nav-item').forEach(function(item,i){
      var next=item.nextElementSibling,sub=null;
      if(next&&(next.classList.contains('topic-nav')||next.classList.contains('nav-sub'))){
        sub=next;
      } else {
        var coll=[],n=item.nextElementSibling;
        while(n&&n.classList.contains('topic-nav-item')){coll.push(n);n=n.nextElementSibling;}
        if(coll.length){
          var w=document.createElement('div');w.className='topic-nav';
          item.parentNode.insertBefore(w,coll[0]);
          coll.forEach(function(x){w.appendChild(x)});
          sub=w;
        }
      }
      if(!sub)return;
      sub.classList.add('nav-sub');
      sub.style.overflow='hidden';sub.style.transition='max-height .3s ease';
      var arr=document.createElement('span');
      arr.className='nav-arrow';arr.textContent='▶';
      item.appendChild(arr);item.style.cursor='pointer';
      var href=item.getAttribute('href')||'';
      var key='itm'+i;
      var open=S[key]!==undefined?S[key]:item.classList.contains('active');
      sub.style.maxHeight=open?'2000px':'0';
      arr.style.transform=open?'rotate(90deg)':'';
      item.addEventListener('click',function(e){
        if(href&&href!=='#'&&!item.classList.contains('active'))return;
        e.preventDefault();
        var o=sub.style.maxHeight==='0px';
        sub.style.maxHeight=o?'2000px':'0';
        arr.style.transform=o?'rotate(90deg)':'';
        sv(key,o);
      });
    });
  })();
  </script>
</body>
