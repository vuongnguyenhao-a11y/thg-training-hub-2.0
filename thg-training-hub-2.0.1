    .user-pill{display:flex;align-items:center;gap:8px;background:rgba(255,255,255,.12);border-radius:20px;padding:4px 12px 4px 6px}
    .user-pill .avatar{width:26px;height:26px;border-radius:50%;background:var(--orange);color:#fff;font-size:11px;font-weight:700;display:flex;align-items:center;justify-content:center}
    .user-pill span{color:rgba(255,255,255,.85);font-size:12px}

    /* SIDEBAR */
    .sidebar{position:fixed;top:var(--header-h);left:0;bottom:0;width:var(--sidebar-w);background:#fff;border-right:1px solid var(--gray-200);overflow-y:auto;z-index:100;transition:transform .25s ease}
    .sidebar::-webkit-scrollbar{width:4px}
    .sidebar::-webkit-scrollbar-thumb{background:var(--gray-200);border-radius:4px}
    .nav-section{padding:16px 0 4px}
    .nav-section-label{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1.2px;color:var(--gray-400);padding:0 16px 6px}
    .nav-item{display:flex;align-items:center;gap:10px;padding:9px 16px;text-decoration:none;color:var(--gray-700);font-size:13.5px;font-weight:500;transition:background .15s;position:relative}
    .nav-item:hover{background:var(--gray-50)}
    .nav-item.active{background:var(--orange-bg);color:#c2410c;font-weight:600}
    .nav-item.active::before{content:'';position:absolute;left:0;top:4px;bottom:4px;width:3px;background:var(--orange);border-radius:0 3px 3px 0}
    .nav-item .nav-icon{font-size:16px;flex-shrink:0;width:20px;text-align:center}
    .nav-badge{margin-left:auto;background:var(--orange);color:#fff;font-size:10px;font-weight:700;padding:1px 6px;border-radius:10px}
    .nav-badge.blue{background:var(--blue)} .nav-badge.green{background:var(--green)}
    .nav-divider{height:1px;background:var(--gray-100);margin:8px 16px}
    .topic-nav-item{display:flex;align-items:center;gap:8px;padding:7px 16px 7px 32px;font-size:12.5px;color:var(--gray-600);text-decoration:none;transition:color .15s,background .15s}
    .topic-nav-item:hover{background:var(--gray-50);color:var(--orange)}
    .topic-nav-item.current{color:var(--orange);font-weight:600}
    .topic-num{font-size:10px;font-weight:700;background:var(--gray-200);color:var(--gray-600);padding:1px 6px;border-radius:10px;flex-shrink:0}
    .topic-nav-item.current .topic-num{background:var(--orange-bg);color:var(--orange)}

    /* MAIN */
    .main{margin-left:var(--sidebar-w);margin-top:var(--header-h);min-height:calc(100vh - var(--header-h));padding:28px 32px 64px}

