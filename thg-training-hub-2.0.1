.meta-pill span{color:#1e293b;font-weight:600}
.meta-pill.red{background:var(--critical-bg);color:var(--critical)}
.meta-pill.amber{background:var(--warning-bg);color:#b45309}
.real-case{background:#fef9ec;border-left:3px solid var(--orange);border-radius:0 8px 8px 0;padding:10px 14px;margin-top:14px;font-size:.82rem;color:#78350f;font-style:italic}
/* RESPONSIVE */
@media(max-width:768px){
