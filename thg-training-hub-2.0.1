    /* PROCESS FLOW */
    .process-flow{display:flex;align-items:flex-start;gap:0;flex-wrap:nowrap;overflow-x:auto;padding-bottom:8px;margin-bottom:20px}
    .pf-step{display:flex;flex-direction:column;align-items:center;gap:6px;flex-shrink:0}
