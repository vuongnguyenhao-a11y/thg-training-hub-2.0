    .section-hd .topic-badge.red{background:var(--red)}
    .section-hd .topic-badge.blue{background:var(--blue)}
    .section-hd h2{font-size:16px;font-weight:700;color:var(--gray-900)}

    .note{border-radius:10px;padding:14px 16px;margin-bottom:14px;display:flex;gap:10px}
    .note.info  {background:var(--blue-light);border-left:3px solid var(--blue)}
    .note.warn  {background:var(--yellow-bg);border-left:3px solid var(--yellow)}
    .note.teal  {background:var(--teal-bg);border-left:3px solid var(--teal)}
    .note.danger{background:var(--red-bg);border-left:3px solid var(--red)}
    .note.tip   {background:var(--orange-bg);border-left:3px solid var(--orange)}
    .note .ni{font-size:16px;flex-shrink:0;margin-top:1px}
    .note .nt{font-size:13px;color:var(--gray-700)}
    .note .nt strong{color:var(--gray-900)}

    .tbl-wrap{overflow-x:auto;margin-bottom:16px}
    table{width:100%;border-collapse:collapse;font-size:13px}
    thead th{background:var(--teal);color:#fff;padding:9px 12px;text-align:left;font-weight:600;font-size:12px}
    tbody td{padding:9px 12px;border-bottom:1px solid var(--gray-100);vertical-align:top}
    tbody tr:last-child td{border-bottom:none}
    tbody tr:nth-child(even){background:var(--gray-50)}

    /* DEPT CARDS */
    .dept-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:12px;margin-bottom:20px}
    .dept-card{border-radius:12px;padding:16px;border:1px solid;text-align:center}
    .dept-card .dc-icon{font-size:28px;margin-bottom:8px}
    .dept-card h4{font-size:12.5px;font-weight:700;margin-bottom:4px}
    .dept-card p{font-size:11.5px;opacity:.8;line-height:1.5}
    .dept-sale   {background:var(--orange-bg);border-color:#fed7aa;color:#c2410c}
    .dept-cskh   {background:var(--blue-light);border-color:#bfdbfe;color:var(--blue-dark)}
    .dept-ops    {background:var(--green-bg);border-color:#86efac;color:#15803d}
    .dept-fin    {background:var(--purple-bg);border-color:#c4b5fd;color:var(--purple)}
    .dept-wh     {background:var(--teal-bg);border-color:#99f6e4;color:var(--teal)}
    .dept-bgd    {background:var(--red-bg);border-color:#fca5a5;color:var(--red)}

    /* FLOW */
    .flow-steps{display:flex;flex-direction:column;gap:0}
    .flow-step{display:flex;gap:16px;position:relative;padding-bottom:20px}
    .flow-step:last-child{padding-bottom:0}
    .flow-step:last-child .fs-line{display:none}
    .fs-left{display:flex;flex-direction:column;align-items:center;flex-shrink:0;width:36px}
    .fs-num{width:36px;height:36px;border-radius:50%;background:var(--teal);color:#fff;font-weight:700;font-size:14px;display:flex;align-items:center;justify-content:center;flex-shrink:0;z-index:1}
    .fs-num.orange{background:var(--orange)} .fs-num.blue{background:var(--blue)}
    .fs-num.green{background:var(--green)} .fs-num.red{background:var(--red)}
    .fs-num.purple{background:var(--purple)}
    .fs-line{flex:1;width:2px;background:var(--gray-200);margin:4px 0}
    .fs-body{flex:1;padding-top:6px}
    .fs-body h4{font-size:13.5px;font-weight:700;color:var(--gray-900);margin-bottom:4px}
    .fs-body p{font-size:13px;color:var(--gray-600)}
    .fs-body ul{padding-left:16px;margin-top:6px}
    .fs-body ul li{font-size:13px;color:var(--gray-600);margin-bottom:3px}
    .fs-tag{display:inline-block;font-size:10px;font-weight:700;padding:2px 8px;border-radius:10px;margin-right:4px;margin-bottom:6px}
    .fs-tag.sale  {background:var(--orange-bg);color:#c2410c}
    .fs-tag.cskh  {background:var(--blue-light);color:var(--blue-dark)}
    .fs-tag.ops   {background:var(--green-bg);color:#15803d}
    .fs-tag.fin   {background:var(--purple-bg);color:var(--purple)}
    .fs-tag.wh    {background:var(--teal-bg);color:var(--teal)}
    .fs-tag.bgd   {background:var(--red-bg);color:var(--red)}

    /* ESCALATION LEVELS */
    .esc-grid{display:flex;flex-direction:column;gap:10px;margin-bottom:16px}
    .esc-row{display:flex;align-items:stretch;gap:0;border-radius:10px;overflow:hidden;border:1px solid var(--gray-200)}
    .esc-level{width:80px;min-width:80px;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:14px 8px;font-weight:700;font-size:12px;text-align:center;color:#fff;flex-shrink:0}
    .esc-level.l1{background:var(--green)}
    .esc-level.l2{background:var(--yellow)}
    .esc-level.l3{background:var(--orange)}
    .esc-level.l4{background:var(--red)}
    .esc-level .lv-num{font-size:18px;font-weight:800}
    .esc-body{flex:1;padding:14px 16px;background:#fff}
    .esc-body h4{font-size:13.5px;font-weight:700;color:var(--gray-900);margin-bottom:4px}
    .esc-body p{font-size:12.5px;color:var(--gray-600)}
    .esc-who{display:flex;gap:6px;flex-wrap:wrap;margin-top:8px}
    .esc-meta{min-width:120px;padding:14px 12px;background:var(--gray-50);display:flex;flex-direction:column;justify-content:center;gap:4px;border-left:1px solid var(--gray-100)}
    .esc-time{font-size:11px;font-weight:700;color:var(--gray-900)}
    .esc-time-label{font-size:10.5px;color:var(--gray-400)}

    /* SCENARIO CARDS */
    .scenario-list{display:flex;flex-direction:column;gap:12px;margin-bottom:16px}
    .scenario{background:#fff;border:1px solid var(--gray-200);border-radius:10px;overflow:hidden}
    .scenario-hd{padding:12px 16px;display:flex;align-items:center;gap:10px;cursor:pointer;user-select:none;transition:background .15s}
    .scenario-hd:hover{background:var(--gray-50)}
    .scenario-hd .sc-icon{font-size:18px;flex-shrink:0}
    .scenario-hd h4{font-size:13.5px;font-weight:700;color:var(--gray-900);flex:1}
    .scenario-hd .sc-tags{display:flex;gap:6px;flex-wrap:wrap}
    .scenario-hd .sc-toggle{color:var(--gray-400);font-size:12px;transition:transform .25s}
    .scenario-hd.open .sc-toggle{transform:rotate(180deg)}
    .scenario-body{display:none;padding:16px;border-top:1px solid var(--gray-100);font-size:13px;color:var(--gray-700);line-height:1.7}
    .scenario-body ol{padding-left:18px}
    .scenario-body ol li{margin-bottom:5px}
    .sc-flow{display:flex;gap:4px;align-items:center;flex-wrap:wrap;margin-top:10px}
    .sc-flow-step{background:var(--gray-100);border-radius:6px;padding:4px 10px;font-size:12px;font-weight:600;color:var(--gray-700)}
    .sc-flow-arrow{color:var(--gray-400);font-size:12px}

    /* LARK GUIDE */
    .lark-step-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:12px;margin-bottom:16px}
    .lark-step{background:#fff;border:1px solid var(--gray-200);border-radius:10px;padding:16px;text-align:center}
    .lark-step .ls-num{width:32px;height:32px;border-radius:50%;background:var(--teal);color:#fff;font-size:13px;font-weight:700;display:flex;align-items:center;justify-content:center;margin:0 auto 8px}
    .lark-step h4{font-size:12.5px;font-weight:700;color:var(--gray-900);margin-bottom:4px}
    .lark-step p{font-size:12px;color:var(--gray-600)}

    /* MATRIX */
    .big-matrix thead th{font-size:11.5px;text-align:center}
    .big-matrix thead th:first-child{text-align:left}
    .big-matrix td{text-align:center;font-size:12.5px}
    .big-matrix td:first-child{text-align:left;font-weight:600;font-size:13px;color:var(--gray-900)}
    .r-dot{display:inline-block;width:22px;height:22px;border-radius:50%;font-size:11px;font-weight:700;line-height:22px}
    .r-dot.p{background:var(--teal);color:#fff}
    .r-dot.s{background:var(--blue-light);color:var(--blue);border:1.5px solid var(--blue)}
    .r-dot.i{background:var(--gray-100);color:var(--gray-600)}
    .r-dot.n{color:var(--gray-200);font-size:14px}

    .overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.4);z-index:90}
    .overlay.show{display:block}

    @media(max-width:768px){
      .menu-toggle{display:block}
      .sidebar{transform:translateX(-100%)}
      .sidebar.open{transform:translateX(0)}
      .main{margin-left:0;padding:20px 16px 64px}
      .module-hero{flex-direction:column;gap:12px}
      .esc-meta{display:none}
      .dept-grid{grid-template-columns:repeat(3,1fr)}
    }
  
    /* ── SIDEBAR DROPDOWN TOGGLE ── */
    .nav-section-label{cursor:pointer;user-select:none;display:flex!important;align-items:center}
    .nav-arrow{margin-left:auto;font-size:9px;opacity:.45;transition:transform .3s ease;display:inline-block;flex-shrink:0;line-height:1;pointer-events:none}
    .nav-section-body{overflow:hidden;transition:max-height .3s ease}
    .nav-sub{overflow:hidden;transition:max-height .3s ease}
  </style>
</head>
