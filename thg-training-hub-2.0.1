<script>
  function toggleSidebar(){
    document.getElementById('sidebar').classList.toggle('open');
    document.getElementById('overlay').classList.toggle('visible');
  }
  function togglePolicy(h){
    const b=h.nextElementSibling,t=h.querySelector('.toggle');
    b.classList.toggle('open');
    t.style.transform=b.classList.contains('open')?'rotate(180deg)':'';
  }
  const secs=document.querySelectorAll('.sop-block,.content-section');
  const navs=document.querySelectorAll('.topic-nav-item');
  window.addEventListener('scroll',()=>{
    let cur='';
    secs.forEach(s=>{if(window.scrollY>=s.offsetTop-80)cur=s.id});
    navs.forEach(n=>n.classList.toggle('current',n.getAttribute('href')==='#'+cur));
  });

  /* ── SIDEBAR DROPDOWN TOGGLE ── */
  (function(){
    var K='thg_nav2',S;
    try{S=JSON.parse(localStorage.getItem(K)||'{}')}catch(e){S={}}
    function sv(k,v){S[k]=v;try{localStorage.setItem(K,JSON.stringify(S))}catch(e){}}
    var sb=document.getElementById('sidebar');
    if(!sb)return;
    // 1. nav-section-label toggles
    sb.querySelectorAll('.nav-section').forEach(function(sec,i){
      var lbl=sec.querySelector('.nav-section-label');
      if(!lbl)return;
      var key='sec'+i;
      var body=document.createElement('div');
      body.className='nav-section-body';
      var kids=[].slice.call(sec.children).filter(function(c){return c!==lbl});
      kids.forEach(function(c){body.appendChild(c)});
      sec.appendChild(body);
      var arr=document.createElement('span');
      arr.className='nav-arrow';arr.textContent='▶';lbl.appendChild(arr);
      var open=S[key]!==undefined?S[key]:true;
      body.style.maxHeight=open?'2000px':'0';
      arr.style.transform=open?'rotate(90deg)':'';
      lbl.addEventListener('click',function(){
        var o=body.style.maxHeight==='0px';
        body.style.maxHeight=o?'2000px':'0';
        arr.style.transform=o?'rotate(90deg)':'';
        sv(key,o);
      });
    });
    // 2. nav-item sub-topic toggles
    sb.querySelectorAll('.nav-item').forEach(function(item,i){
      var next=item.nextElementSibling,sub=null;
      if(next&&(next.classList.contains('topic-nav')||next.classList.contains('nav-sub'))){
        sub=next;
      } else {
        var coll=[],n=item.nextElementSibling;
        while(n&&n.classList.contains('topic-nav-item')){coll.push(n);n=n.nextElementSibling;}
        if(coll.length){
          var w=document.createElement('div');w.className='topic-nav';
          item.parentNode.insertBefore(w,coll[0]);
          coll.forEach(function(x){w.appendChild(x)});
          sub=w;
        }
      }
      if(!sub)return;
      sub.classList.add('nav-sub');
      sub.style.overflow='hidden';sub.style.transition='max-height .3s ease';
      var arr=document.createElement('span');
      arr.className='nav-arrow';arr.textContent='▶';
      item.appendChild(arr);item.style.cursor='pointer';
      var href=item.getAttribute('href')||'';
      var key='itm'+i;
      var open=S[key]!==undefined?S[key]:item.classList.contains('active');
      sub.style.maxHeight=open?'2000px':'0';
      arr.style.transform=open?'rotate(90deg)':'';
      item.addEventListener('click',function(e){
        if(href&&href!=='#'&&!item.classList.contains('active'))return;
        e.preventDefault();
        var o=sub.style.maxHeight==='0px';
        sub.style.maxHeight=o?'2000px':'0';
        arr.style.transform=o?'rotate(90deg)':'';
        sv(key,o);
      });
    });
  })();
  </script>
</body>
</html>

<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>SOP Finance & Công Nợ | THG Training Hub</title>
  <style>
    :root {
      --blue:#1B4FBB; --blue-dark:#143d94; --blue-light:#e8eefb;
      --orange:#F97316; --orange-bg:#fff4ed;
      --green:#16a34a; --green-bg:#f0fdf4;
      --red:#dc2626; --red-bg:#fef2f2;
      --yellow:#ca8a04; --yellow-bg:#fefce8;
      --purple:#7c3aed; --purple-bg:#f3e8ff;
      --teal:#0d9488; --teal-bg:#f0fdfa;
      --gray-50:#f8fafc; --gray-100:#f1f5f9; --gray-200:#e2e8f0;
      --gray-400:#94a3b8; --gray-600:#475569; --gray-700:#334155; --gray-900:#0f172a;
      --sidebar-w:260px; --header-h:56px;
    }
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:var(--gray-50);color:var(--gray-700);font-size:14px;line-height:1.6}

    /* TOPBAR */
    .topbar{position:fixed;top:0;left:0;right:0;z-index:200;height:var(--header-h);background:var(--blue);display:flex;align-items:center;justify-content:space-between;padding:0 20px;box-shadow:0 1px 8px rgba(0,0,0,.25)}
    .topbar-left{display:flex;align-items:center;gap:12px}
    .menu-toggle{display:none;background:none;border:none;color:#fff;font-size:20px;cursor:pointer}
    .topbar-logo{display:flex;align-items:center;gap:8px}
    .topbar-logo .badge{background:var(--orange);color:#fff;font-size:10px;font-weight:700;letter-spacing:1px;text-transform:uppercase;padding:2px 7px;border-radius:4px}
    .topbar-logo span{color:#fff;font-size:15px;font-weight:700}
    .user-pill{display:flex;align-items:center;gap:8px;background:rgba(255,255,255,.12);border-radius:20px;padding:4px 12px 4px 6px}
    .user-pill .avatar{width:26px;height:26px;border-radius:50%;background:var(--orange);color:#fff;font-size:11px;font-weight:700;display:flex;align-items:center;justify-content:center}
    .user-pill span{color:rgba(255,255,255,.85);font-size:12px}

    /* SIDEBAR */
    .sidebar{position:fixed;top:var(--header-h);left:0;bottom:0;width:var(--sidebar-w);background:#fff;border-right:1px solid var(--gray-200);overflow-y:auto;z-index:100;transition:transform .25s ease}
    .sidebar::-webkit-scrollbar{width:4px}
    .sidebar::-webkit-scrollbar-thumb{background:var(--gray-200);border-radius:4px}
    .nav-section{padding:16px 0 4px}
    .nav-section-label{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1.2px;color:var(--gray-400);padding:0 16px 6px}
    .nav-item{display:flex;align-items:center;gap:10px;padding:9px 16px;text-decoration:none;color:var(--gray-700);font-size:13.5px;font-weight:500;transition:background .15s;position:relative}
    .nav-item:hover{background:var(--gray-50)}
    .nav-item.active{background:var(--blue-light);color:var(--blue-dark);font-weight:600}
    .nav-item.active::before{content:'';position:absolute;left:0;top:4px;bottom:4px;width:3px;background:var(--blue);border-radius:0 3px 3px 0}
    .nav-item .nav-icon{font-size:16px;flex-shrink:0;width:20px;text-align:center}
    .nav-badge{margin-left:auto;background:var(--orange);color:#fff;font-size:10px;font-weight:700;padding:1px 6px;border-radius:10px}
    .nav-badge.blue{background:var(--blue)} .nav-badge.green{background:var(--green)} .nav-badge.red{background:var(--red)}
    .nav-divider{height:1px;background:var(--gray-100);margin:8px 16px}
    .topic-nav-item{display:flex;align-items:center;gap:8px;padding:7px 16px 7px 32px;font-size:12.5px;color:var(--gray-600);text-decoration:none;transition:color .15s,background .15s}
    .topic-nav-item:hover{background:var(--gray-50);color:var(--blue)}
    .topic-nav-item.current{color:var(--blue);font-weight:600}
    .topic-num{font-size:10px;font-weight:700;background:var(--gray-200);color:var(--gray-600);padding:1px 6px;border-radius:10px;flex-shrink:0}
    .topic-nav-item.current .topic-num{background:var(--blue-light);color:var(--blue)}

    /* MAIN */
    .main{margin-left:var(--sidebar-w);margin-top:var(--header-h);min-height:calc(100vh - var(--header-h));padding:28px 32px 64px}

    /* BREADCRUMB */
    .breadcrumb{display:flex;align-items:center;gap:6px;font-size:12.5px;color:var(--gray-400);margin-bottom:20px}
    .breadcrumb a{color:var(--blue);text-decoration:none}
    .breadcrumb a:hover{text-decoration:underline}

    /* PRIORITY BANNER */
    .priority-banner{background:linear-gradient(135deg,#dc2626,#b91c1c);color:#fff;border-radius:12px;padding:14px 20px;margin-bottom:20px;display:flex;align-items:center;gap:12px}
    .priority-banner .pb-icon{font-size:20px;flex-shrink:0}
    .priority-banner .pb-text{font-size:13px;font-weight:600}
    .priority-banner .pb-sub{font-size:12px;opacity:.85;margin-top:2px}

    /* HERO */
    .module-hero{background:linear-gradient(135deg,var(--blue-light) 0%,#f0f4ff 100%);border:1px solid #bfdbfe;border-radius:16px;padding:28px 32px;margin-bottom:28px;display:flex;align-items:flex-start;gap:20px}
    .module-hero-icon{font-size:48px;flex-shrink:0}
    .module-hero-body .tag{display:inline-block;background:var(--blue);color:#fff;font-size:11px;font-weight:700;padding:3px 10px;border-radius:4px;margin-bottom:10px;letter-spacing:.5px}
    .module-hero-body .tag.urgent{background:var(--red)}
    .module-hero-body h1{font-size:22px;font-weight:800;color:var(--gray-900);margin-bottom:8px}
    .module-hero-body p{font-size:13.5px;color:var(--gray-600);max-width:600px}
    .module-meta-row{display:flex;gap:20px;margin-top:16px;flex-wrap:wrap}
    .meta-item{font-size:12px;color:var(--gray-600)}
    .meta-item strong{color:var(--gray-900)}

    /* QUICK NAV */
    .module-progress-nav{background:#fff;border:1px solid var(--gray-200);border-radius:12px;padding:14px 20px;margin-bottom:28px;display:flex;gap:8px;flex-wrap:wrap;align-items:center}
    .mpn-label{font-size:12px;font-weight:600;color:var(--gray-400);margin-right:4px}
    .mpn-item{padding:5px 12px;border-radius:20px;font-size:12px;font-weight:600;text-decoration:none;transition:background .15s,color .15s;border:1.5px solid var(--gray-200);color:var(--gray-600);background:var(--gray-50)}
    .mpn-item:hover{border-color:var(--blue);color:var(--blue)}

    /* SOP BLOCKS */
    .sop-block{background:#fff;border:1px solid var(--gray-200);border-radius:14px;overflow:hidden;margin-bottom:24px;scroll-margin-top:calc(var(--header-h) + 16px)}
    .sop-header{padding:18px 24px;display:flex;align-items:center;gap:14px;border-bottom:1px solid var(--gray-200)}
    .sop-header.fin {background:linear-gradient(135deg,var(--blue-light),#f0f4ff)}
    .sop-header.debt{background:linear-gradient(135deg,var(--red-bg),#fff5f5)}
