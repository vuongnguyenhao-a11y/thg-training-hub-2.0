    .comp-card-body{padding:14px 18px;font-size:13px;color:var(--gray-700);line-height:1.7}
    .comp-card-body ul{padding-left:16px}
    .comp-card-body ul li{margin-bottom:4px}

    /* CONTACT INFO */
    .contact-box{background:linear-gradient(135deg,var(--sky),#0369a1);color:#fff;border-radius:14px;padding:24px 28px;margin-bottom:16px}
