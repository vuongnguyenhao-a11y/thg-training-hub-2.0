    .nav-badge.green { background: var(--green); }
    .nav-badge.gray  { background: var(--gray-400); }

    .nav-divider { height: 1px; background: var(--gray-100); margin: 8px 16px; }

    /* ── MAIN ── */
    .main {
      margin-left: var(--sidebar-w);
      margin-top: var(--header-h);
      min-height: calc(100vh - var(--header-h));
      padding: 28px 32px 48px;
    }

    /* ── PAGE HEADER ── */
    .page-header {
      display: flex; align-items: flex-start; justify-content: space-between;
      margin-bottom: 28px; gap: 16px; flex-wrap: wrap;
    }

    .page-header h1 {
      font-size: 22px; font-weight: 700; color: var(--gray-900);
      margin-bottom: 4px;
    }

    .page-header p { font-size: 13px; color: var(--gray-600); }

    .date-badge {
      background: var(--blue-light); color: var(--blue);
      font-size: 12px; font-weight: 600; padding: 6px 14px;
      border-radius: 8px; white-space: nowrap;
    }

    /* ── STATS ROW ── */
    .stats-row {
      display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px;
      margin-bottom: 28px;
    }

    .stat-card {
      background: #fff; border-radius: 12px;
      border: 1px solid var(--gray-200);
      padding: 18px 20px;
      display: flex; align-items: center; gap: 14px;
    }

    .stat-icon {
      width: 44px; height: 44px; border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      font-size: 20px; flex-shrink: 0;
    }

    .stat-icon.blue   { background: var(--blue-light); }
    .stat-icon.orange { background: var(--orange-bg); }
    .stat-icon.green  { background: var(--green-bg); }
    .stat-icon.yellow { background: var(--yellow-bg); }

    .stat-info .val {
      font-size: 22px; font-weight: 800; color: var(--gray-900); line-height: 1;
    }

    .stat-info .lbl { font-size: 12px; color: var(--gray-600); margin-top: 3px; }

    /* ── SECTION TITLE ── */
    .section-hd {
      display: flex; align-items: center; justify-content: space-between;
      margin-bottom: 14px;
    }

    .section-hd h2 {
      font-size: 15px; font-weight: 700; color: var(--gray-900);
      display: flex; align-items: center; gap: 8px;
    }

    .section-hd a {
      font-size: 12px; color: var(--blue); text-decoration: none; font-weight: 600;
    }
    .section-hd a:hover { text-decoration: underline; }

    /* ── MODULE GRID ── */
    .module-grid {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 16px; margin-bottom: 32px;
    }

    .module-card {
      background: #fff; border-radius: 12px;
      border: 1px solid var(--gray-200);
      padding: 20px; cursor: pointer;
      transition: border-color 0.2s, box-shadow 0.2s, transform 0.15s;
      text-decoration: none; color: inherit; display: block;
    }

    .module-card:hover {
      border-color: var(--blue);
      box-shadow: 0 4px 16px rgba(27,79,187,0.1);
      transform: translateY(-2px);
    }

    .module-card-top {
      display: flex; align-items: flex-start; justify-content: space-between;
      margin-bottom: 12px;
    }

    .module-icon-wrap {
      width: 48px; height: 48px; border-radius: 12px;
      display: flex; align-items: center; justify-content: center; font-size: 24px;
    }

    .module-icon-wrap.blue   { background: var(--blue-light); }
    .module-icon-wrap.orange { background: var(--orange-bg); }
    .module-icon-wrap.green  { background: var(--green-bg); }
    .module-icon-wrap.purple { background: #f3e8ff; }

    .module-status {
      font-size: 11px; font-weight: 600; padding: 3px 10px; border-radius: 20px;
    }

    .module-status.active  { background: var(--green-bg);  color: var(--green); }
    .module-status.draft   { background: var(--yellow-bg); color: var(--yellow); }
    .module-status.locked  { background: var(--gray-100);  color: var(--gray-600); }
    .module-status.urgent  { background: var(--red-bg);    color: var(--red); }

    .module-card h3 { font-size: 14px; font-weight: 700; color: var(--gray-900); margin-bottom: 6px; }
    .module-card p  { font-size: 12.5px; color: var(--gray-600); line-height: 1.5; margin-bottom: 14px; }

    .module-meta {
      display: flex; align-items: center; gap: 12px; flex-wrap: wrap;
    }

    .module-meta span {
      display: flex; align-items: center; gap: 4px;
      font-size: 11.5px; color: var(--gray-400);
    }

    .progress-bar-wrap { margin-top: 12px; }

    .progress-bar-label {
      display: flex; justify-content: space-between; margin-bottom: 4px;
      font-size: 11px; color: var(--gray-600);
    }

    .progress-bar {
      height: 5px; background: var(--gray-100); border-radius: 4px; overflow: hidden;
    }

    .progress-bar-fill {
      height: 100%; border-radius: 4px; background: var(--blue);
      transition: width 0.4s ease;
    }

    .progress-bar-fill.orange { background: var(--orange); }
    .progress-bar-fill.green  { background: var(--green); }

    /* ── SOP TABLE ── */
    .sop-table-wrap {
      background: #fff; border-radius: 12px; border: 1px solid var(--gray-200);
      overflow: hidden; margin-bottom: 32px;
    }

    .sop-table { width: 100%; border-collapse: collapse; }

    .sop-table th {
      background: var(--gray-50); text-align: left;
      padding: 10px 16px; font-size: 11.5px; font-weight: 600;
      color: var(--gray-600); text-transform: uppercase; letter-spacing: 0.5px;
      border-bottom: 1px solid var(--gray-200);
    }

    .sop-table td {
      padding: 12px 16px; border-bottom: 1px solid var(--gray-100);
      font-size: 13px;
    }

    .sop-table tr:last-child td { border-bottom: none; }
    .sop-table tr:hover td { background: var(--gray-50); }

    .sop-id {
      font-family: monospace; font-size: 12px; font-weight: 700;
      color: var(--blue); background: var(--blue-light);
      padding: 2px 8px; border-radius: 6px;
    }

    .dept-tag {
      display: inline-block; font-size: 11px; font-weight: 600;
      padding: 2px 9px; border-radius: 12px;
    }

    .dept-tag.sale   { background: #ede9fe; color: #7c3aed; }
    .dept-tag.cskh   { background: var(--orange-bg); color: #c2410c; }
    .dept-tag.ops    { background: var(--blue-light); color: var(--blue); }
    .dept-tag.acct   { background: var(--green-bg); color: var(--green); }
    .dept-tag.cross  { background: var(--yellow-bg); color: var(--yellow); }

    /* ── QUICK LINKS ── */
    .quick-grid {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 12px; margin-bottom: 32px;
    }

    .quick-item {
      background: #fff; border: 1px solid var(--gray-200); border-radius: 10px;
      padding: 14px 16px; display: flex; align-items: center; gap: 12px;
      cursor: pointer; text-decoration: none; color: inherit;
      transition: border-color 0.2s, background 0.15s;
    }

    .quick-item:hover { border-color: var(--orange); background: var(--orange-bg); }

    .quick-item .qi-icon { font-size: 22px; flex-shrink: 0; }

    .quick-item .qi-text .qi-title {
      font-size: 13px; font-weight: 600; color: var(--gray-900);
    }

    .quick-item .qi-text .qi-sub { font-size: 11.5px; color: var(--gray-600); }

    /* ── ANNOUNCEMENT ── */
    .announcement {
      background: var(--orange-bg); border: 1px solid #fed7aa;
      border-left: 4px solid var(--orange);
      border-radius: 10px; padding: 14px 18px;
      display: flex; gap: 12px; align-items: flex-start;
      margin-bottom: 28px;
    }

    .announcement .ann-icon { font-size: 20px; flex-shrink: 0; margin-top: 1px; }

    .announcement .ann-body strong {
      display: block; font-size: 13px; font-weight: 700; color: #9a3412;
      margin-bottom: 3px;
    }

    .announcement .ann-body p { font-size: 12.5px; color: #7c2d12; line-height: 1.5; }

    /* ── FOOTER NOTE ── */
    .footer-note {
      text-align: center; padding-top: 24px;
      border-top: 1px solid var(--gray-200);
      font-size: 11.5px; color: var(--gray-400);
    }

    /* ── MOBILE ── */
    @media (max-width: 768px) {
      .menu-toggle { display: block; }

      .sidebar {
        transform: translateX(-100%);
      }

      .sidebar.open { transform: translateX(0); }

      .main { margin-left: 0; padding: 20px 16px 40px; }

      .stats-row { grid-template-columns: repeat(2, 1fr); }

      .module-grid { grid-template-columns: 1fr; }

      .sop-table th:nth-child(3),
      .sop-table td:nth-child(3) { display: none; }

      .page-header { flex-direction: column; gap: 8px; }

      .overlay {
        display: none; position: fixed; inset: 0;
        background: rgba(0,0,0,0.4); z-index: 99;
      }

      .overlay.visible { display: block; }
    }

    @media (max-width: 480px) {
      .stats-row { grid-template-columns: 1fr 1fr; gap: 10px; }
      .stat-card { padding: 14px; }
      .stat-icon { width: 36px; height: 36px; font-size: 17px; }
      .stat-info .val { font-size: 18px; }
    }
  
    /* ── SIDEBAR DROPDOWN TOGGLE ── */
    .nav-section-label{cursor:pointer;user-select:none;display:flex!important;align-items:center}
    .nav-arrow{margin-left:auto;font-size:9px;opacity:.45;transition:transform .3s ease;display:inline-block;flex-shrink:0;line-height:1;pointer-events:none}
    .nav-section-body{overflow:hidden;transition:max-height .3s ease}
    .nav-sub{overflow:hidden;transition:max-height .3s ease}
  </style>
</head>
