    .module-hero{background:linear-gradient(135deg,var(--orange-bg) 0%,#fff8f5 100%);border:1px solid #fed7aa;border-radius:16px;padding:28px 32px;margin-bottom:28px;display:flex;align-items:flex-start;gap:20px}
