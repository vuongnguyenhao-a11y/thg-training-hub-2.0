    .route-header.vn-global{background:linear-gradient(135deg,var(--green-bg),#dcfce7)}
    .route-header.cn-us{background:linear-gradient(135deg,var(--orange-bg),#fef3c7)}
    .route-flag{font-size:24px}
    .route-arrow{font-size:18px;color:var(--gray-400)}
