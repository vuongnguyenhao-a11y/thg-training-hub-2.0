    .accordion{border:1px solid var(--gray-200);border-radius:10px;overflow:hidden;margin-bottom:12px}
    .accordion-hd{background:#fff;padding:14px 16px;cursor:pointer;display:flex;align-items:center;justify-content:space-between;font-size:13.5px;font-weight:600;color:var(--gray-900);transition:background .15s;user-select:none}
    .accordion-hd:hover{background:var(--gray-50)}
    .accordion-hd .acc-icon{font-size:12px;color:var(--gray-400);transition:transform .25s}
    .accordion-hd.open .acc-icon{transform:rotate(180deg)}
    .accordion-body{display:none;padding:16px;background:#fff;border-top:1px solid var(--gray-100);font-size:13px;color:var(--gray-700);line-height:1.7}
    .accordion-body ul{padding-left:16px}
    .accordion-body ul li{margin-bottom:5px}
    .accordion-body p{margin-bottom:8px}

    /* BANK BOX */
    .bank-box{background:linear-gradient(135deg,#1B4FBB,#143d94);color:#fff;border-radius:14px;padding:24px 28px;margin-bottom:16px}
    .bank-box h3{font-size:16px;font-weight:700;margin-bottom:16px;opacity:.9}
    .bank-row{display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:1px solid rgba(255,255,255,.15)}
    .bank-row:last-child{border-bottom:none}
    .bank-label{font-size:12px;opacity:.7}
    .bank-value{font-size:14px;font-weight:700}
    .bank-value.big{font-size:18px;letter-spacing:2px;font-family:monospace}
    .copy-hint{font-size:11px;opacity:.5;margin-top:16px}

    /* MATRIX */
    .matrix-table thead th{font-size:12px}
    .matrix-table td:first-child{font-weight:600;color:var(--gray-900);background:var(--gray-50)}
    .check{color:var(--green);font-weight:700}
    .cross{color:var(--gray-400)}
    .primary-check{color:var(--blue);font-weight:700}

    /* TIMELINE */
    .timeline{display:flex;gap:0;margin-bottom:16px;overflow-x:auto;padding-bottom:4px}
    .tl-item{flex:1;min-width:110px;text-align:center;position:relative}
    .tl-item:not(:last-child)::after{content:'→';position:absolute;right:-8px;top:18px;color:var(--gray-400);font-size:14px}
    .tl-circle{width:40px;height:40px;border-radius:50%;background:var(--blue);color:#fff;font-size:12px;font-weight:700;display:flex;align-items:center;justify-content:center;margin:0 auto 8px}
    .tl-circle.warn{background:var(--yellow)}
    .tl-circle.danger{background:var(--red)}
    .tl-circle.success{background:var(--green)}
    .tl-label{font-size:11.5px;font-weight:600;color:var(--gray-900)}
    .tl-sub{font-size:11px;color:var(--gray-600)}

    /* OVERLAY */
    .overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.4);z-index:90}
    .overlay.show{display:block}

    /* RESPONSIVE */
    @media(max-width:768px){
      .menu-toggle{display:block}
