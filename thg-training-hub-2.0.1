/* SIDEBAR */
.sidebar{position:fixed;top:var(--top);left:0;width:var(--sidebar);height:calc(100vh - var(--top));background:#fff;border-right:1px solid #e2e8f0;overflow-y:auto;z-index:90}
.nav-section{padding:12px 0 4px}
.nav-section-label{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1.2px;color:#94a3b8;padding:0 16px 6px;display:flex;align-items:center}
.nav-item{display:flex;align-items:center;gap:10px;padding:9px 16px;text-decoration:none;color:#475569;font-size:13.5px;font-weight:500;transition:background .15s;position:relative}
.nav-item:hover{background:#f8fafc;color:var(--blue)}
.nav-item.active{background:#eff6ff;color:var(--blue);font-weight:600}
.nav-item.active::before{content:'';position:absolute;left:0;top:4px;bottom:4px;width:3px;background:var(--blue);border-radius:0 3px 3px 0}
.nav-item .nav-icon{font-size:15px;flex-shrink:0;width:20px;text-align:center}
.nav-divider{height:1px;background:#f1f5f9;margin:4px 16px}
/* MAIN */
.main{margin-left:var(--sidebar);margin-top:var(--top);padding:32px 40px;min-height:calc(100vh - var(--top))}
/* PAGE HERO */
.page-hero{background:linear-gradient(135deg,var(--blue) 0%,#1e3a8a 100%);border-radius:16px;padding:36px 40px;color:#fff;margin-bottom:32px}
.page-hero h1{font-size:1.8rem;font-weight:800;margin-bottom:8px}
.page-hero p{opacity:.85;font-size:.95rem;max-width:600px;line-height:1.6}
.hero-stats{display:flex;gap:24px;margin-top:20px;flex-wrap:wrap}
