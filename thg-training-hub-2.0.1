    .user-pill .avatar { width: 26px; height: 26px; border-radius: 50%; background: var(--orange); color: #fff; font-size: 11px; font-weight: 700; display: flex; align-items: center; justify-content: center; }
    .user-pill span { color: rgba(255,255,255,0.85); font-size: 12px; }

    /* ── SIDEBAR ── */
    .sidebar {
      position: fixed; top: var(--header-h); left: 0; bottom: 0;
