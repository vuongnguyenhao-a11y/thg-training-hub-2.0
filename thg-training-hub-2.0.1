<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dropship | THG Training Hub</title>
  <style>
    :root {
      --blue:       #1B4FBB;
      --blue-dark:  #143d94;
      --blue-light: #e8eefb;
      --orange:     #F97316;
      --orange-bg:  #fff4ed;
      --green:      #16a34a;
      --green-bg:   #f0fdf4;
      --red:        #dc2626;
      --red-bg:     #fef2f2;
      --yellow:     #ca8a04;
      --yellow-bg:  #fefce8;
      --purple:     #7c3aed;
      --purple-bg:  #f3e8ff;
      --gray-50:    #f8fafc;
      --gray-100:   #f1f5f9;
      --gray-200:   #e2e8f0;
      --gray-400:   #94a3b8;
      --gray-600:   #475569;
      --gray-700:   #334155;
      --gray-900:   #0f172a;
      --sidebar-w:  260px;
      --header-h:   56px;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: var(--gray-50); color: var(--gray-700); font-size: 14px; line-height: 1.6; }

    /* TOPBAR */
    .topbar { position: fixed; top: 0; left: 0; right: 0; z-index: 200; height: var(--header-h); background: var(--blue); display: flex; align-items: center; justify-content: space-between; padding: 0 20px; box-shadow: 0 1px 8px rgba(0,0,0,0.25); }
    .topbar-left { display: flex; align-items: center; gap: 12px; }
    .menu-toggle { display: none; background: none; border: none; color: #fff; font-size: 20px; cursor: pointer; }
    .topbar-logo { display: flex; align-items: center; gap: 8px; }
    .topbar-logo .badge { background: var(--orange); color: #fff; font-size: 10px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; padding: 2px 7px; border-radius: 4px; }
    .topbar-logo span { color: #fff; font-size: 15px; font-weight: 700; }
    .user-pill { display: flex; align-items: center; gap: 8px; background: rgba(255,255,255,0.12); border-radius: 20px; padding: 4px 12px 4px 6px; }
    .user-pill .avatar { width: 26px; height: 26px; border-radius: 50%; background: var(--orange); color: #fff; font-size: 11px; font-weight: 700; display: flex; align-items: center; justify-content: center; }
    .user-pill span { color: rgba(255,255,255,0.85); font-size: 12px; }

    /* SIDEBAR */
    .sidebar { position: fixed; top: var(--header-h); left: 0; bottom: 0; width: var(--sidebar-w); background: #fff; border-right: 1px solid var(--gray-200); overflow-y: auto; z-index: 100; transition: transform 0.25s ease; }
    .sidebar::-webkit-scrollbar { width: 4px; }
    .sidebar::-webkit-scrollbar-thumb { background: var(--gray-200); border-radius: 4px; }
    .nav-section { padding: 16px 0 4px; }
    .nav-section-label { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 1.2px; color: var(--gray-400); padding: 0 16px 6px; }
    .nav-item { display: flex; align-items: center; gap: 10px; padding: 9px 16px; text-decoration: none; color: var(--gray-700); font-size: 13.5px; font-weight: 500; transition: background 0.15s; position: relative; }
    .nav-item:hover { background: var(--gray-50); }
    .nav-item.active { background: var(--blue-light); color: var(--blue); font-weight: 600; }
    .nav-item.active::before { content: ''; position: absolute; left: 0; top: 4px; bottom: 4px; width: 3px; background: var(--blue); border-radius: 0 3px 3px 0; }
    .nav-item .nav-icon { font-size: 16px; flex-shrink: 0; width: 20px; text-align: center; }
    .nav-badge { margin-left: auto; background: var(--orange); color: #fff; font-size: 10px; font-weight: 700; padding: 1px 6px; border-radius: 10px; }
    .nav-badge.blue  { background: var(--blue); }
    .nav-badge.green { background: var(--green); }
    .nav-divider { height: 1px; background: var(--gray-100); margin: 8px 16px; }
    .topic-nav-item { display: flex; align-items: center; gap: 8px; padding: 7px 16px 7px 32px; font-size: 12.5px; color: var(--gray-600); text-decoration: none; transition: color 0.15s, background 0.15s; }
    .topic-nav-item:hover { background: var(--gray-50); color: var(--blue); }
    .topic-nav-item.current { color: var(--blue); font-weight: 600; }
    .topic-num { font-size: 10px; font-weight: 700; background: var(--gray-200); color: var(--gray-600); padding: 1px 6px; border-radius: 10px; flex-shrink: 0; }
    .topic-nav-item.current .topic-num { background: var(--blue-light); color: var(--blue); }

    /* MAIN */
    .main { margin-left: var(--sidebar-w); margin-top: var(--header-h); min-height: calc(100vh - var(--header-h)); padding: 28px 32px 64px; }

    /* BREADCRUMB */
    .breadcrumb { display: flex; align-items: center; gap: 6px; font-size: 12.5px; color: var(--gray-400); margin-bottom: 20px; }
    .breadcrumb a { color: var(--blue); text-decoration: none; }
    .breadcrumb a:hover { text-decoration: underline; }

    /* MODULE HERO */
    .module-hero { background: linear-gradient(135deg, var(--blue-light) 0%, #f0f4ff 100%); border: 1px solid #c7d7f5; border-radius: 16px; padding: 28px 32px; margin-bottom: 28px; display: flex; align-items: flex-start; gap: 20px; }
    .module-hero-icon { font-size: 48px; flex-shrink: 0; }
    .module-hero-body { flex: 1; }
    .module-hero-body .tag { display: inline-block; background: var(--blue); color: #fff; font-size: 11px; font-weight: 700; padding: 3px 10px; border-radius: 4px; margin-bottom: 10px; letter-spacing: 0.5px; }
    .module-hero-body h1 { font-size: 22px; font-weight: 800; color: var(--gray-900); margin-bottom: 8px; }
    .module-hero-body p  { font-size: 13.5px; color: var(--gray-600); max-width: 600px; }
    .module-meta-row { display: flex; gap: 20px; margin-top: 16px; flex-wrap: wrap; }
    .meta-item { font-size: 12px; color: var(--gray-600); }
    .progress-hero-wrap { flex-shrink: 0; text-align: right; }
    .progress-circle { width: 72px; height: 72px; }
    .pct { font-size: 13px; font-weight: 700; color: var(--blue); margin-top: 6px; text-align: center; }

    /* QUICK NAV */
    .module-progress-nav { background: #fff; border: 1px solid var(--gray-200); border-radius: 12px; padding: 16px 20px; margin-bottom: 28px; display: flex; gap: 8px; flex-wrap: wrap; align-items: center; }
    .mpn-label { font-size: 12px; font-weight: 600; color: var(--gray-400); margin-right: 4px; }
    .mpn-item { padding: 5px 12px; border-radius: 20px; font-size: 12px; font-weight: 600; cursor: pointer; text-decoration: none; transition: background 0.15s, color 0.15s; border: 1.5px solid var(--gray-200); color: var(--gray-600); background: var(--gray-50); }
    .mpn-item:hover { border-color: var(--blue); color: var(--blue); }

    /* CONTENT SECTIONS */
    .content-section { margin-bottom: 36px; scroll-margin-top: calc(var(--header-h) + 16px); }
    .section-hd { display: flex; align-items: center; gap: 10px; margin-bottom: 16px; padding-bottom: 10px; border-bottom: 2px solid var(--gray-100); }
    .section-hd .topic-badge { background: var(--blue); color: #fff; font-size: 10px; font-weight: 700; padding: 3px 9px; border-radius: 6px; letter-spacing: 0.5px; flex-shrink: 0; }
    .section-hd h2 { font-size: 16px; font-weight: 700; color: var(--gray-900); }

    /* NOTE BOXES */
    .note-box { border-radius: 10px; padding: 14px 18px; display: flex; gap: 12px; align-items: flex-start; margin-bottom: 16px; }
    .note-box.info   { background: var(--blue-light);  border-left: 4px solid var(--blue);   }
    .note-box.warn   { background: var(--yellow-bg);   border-left: 4px solid var(--yellow); }
    .note-box.danger { background: var(--red-bg);      border-left: 4px solid var(--red);    }
    .note-box.success{ background: var(--green-bg);    border-left: 4px solid var(--green);  }
    .note-box .nb-icon { font-size: 18px; flex-shrink: 0; margin-top: 1px; }
    .note-box p { font-size: 13px; line-height: 1.6; }
    .note-box.info   p { color: #1e3a8a; }
    .note-box.warn   p { color: #713f12; }
    .note-box.danger p { color: #991b1b; }
    .note-box.success p { color: #14532d; }

    /* INFO GRID */
    .info-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 16px; }
    .info-card { background: #fff; border: 1px solid var(--gray-200); border-radius: 12px; padding: 20px; }
    .info-card .ic-header { display: flex; align-items: center; gap: 10px; margin-bottom: 12px; }
    .info-card .ic-icon { width: 38px; height: 38px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 18px; flex-shrink: 0; }
    .ic-icon.orange { background: var(--orange-bg); }
    .ic-icon.blue   { background: var(--blue-light); }
    .ic-icon.green  { background: var(--green-bg); }
    .ic-icon.purple { background: var(--purple-bg); }
    .ic-icon.yellow { background: var(--yellow-bg); }
    .info-card h3 { font-size: 13.5px; font-weight: 700; color: var(--gray-900); }
    .info-card ul { list-style: none; }
    .info-card ul li { display: flex; gap: 8px; font-size: 12.5px; color: var(--gray-600); margin-bottom: 7px; align-items: flex-start; line-height: 1.5; }
    .info-card ul li::before { content: '›'; color: var(--blue); font-weight: 700; font-size: 14px; flex-shrink: 0; margin-top: -1px; }

    /* FLOW STEPS */
    .flow-wrap { display: flex; flex-direction: column; gap: 0; }
    .flow-step { display: flex; gap: 16px; align-items: flex-start; }
    .flow-step-left { display: flex; flex-direction: column; align-items: center; flex-shrink: 0; }
    .flow-dot { width: 36px; height: 36px; border-radius: 50%; background: var(--blue); color: #fff; font-size: 13px; font-weight: 700; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .flow-line { width: 2px; flex: 1; background: var(--gray-200); margin: 4px 0; min-height: 24px; }
    .flow-step:last-child .flow-line { display: none; }
    .flow-body { background: #fff; border: 1px solid var(--gray-200); border-radius: 12px; padding: 16px 20px; margin-bottom: 12px; flex: 1; }
    .flow-body h4 { font-size: 13.5px; font-weight: 700; color: var(--gray-900); margin-bottom: 6px; }
    .flow-body p  { font-size: 12.5px; color: var(--gray-600); line-height: 1.6; }
    .flow-body ul { list-style: none; margin-top: 6px; }
    .flow-body ul li { font-size: 12.5px; color: var(--gray-600); margin-bottom: 4px; padding-left: 14px; position: relative; }
    .flow-body ul li::before { content: '·'; position: absolute; left: 0; color: var(--blue); font-weight: 900; }
    .flow-tag { display: inline-block; font-size: 10px; font-weight: 700; padding: 2px 8px; border-radius: 4px; margin-bottom: 8px; }
    .flow-tag.daily  { background: var(--green-bg); color: var(--green); }
    .flow-tag.weekly { background: var(--yellow-bg); color: var(--yellow); }
    .flow-tag.ondemand { background: var(--blue-light); color: var(--blue); }

    /* SUPPLIER CARDS */
    .supplier-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 16px; }
    .supplier-card { background: #fff; border: 1px solid var(--gray-200); border-radius: 12px; padding: 20px; transition: border-color 0.2s, box-shadow 0.2s; }
    .supplier-card:hover { border-color: var(--blue); box-shadow: 0 4px 14px rgba(27,79,187,0.1); }
    .supplier-card .sc-top { display: flex; align-items: center; gap: 10px; margin-bottom: 12px; }
    .supplier-card .sc-icon { width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 20px; }
    .supplier-card h3 { font-size: 14px; font-weight: 700; color: var(--gray-900); }
    .supplier-card p  { font-size: 12.5px; color: var(--gray-600); line-height: 1.5; margin-bottom: 10px; }
    .supplier-card .sc-tags { display: flex; gap: 6px; flex-wrap: wrap; }
    .sc-tag { font-size: 11px; font-weight: 600; padding: 2px 9px; border-radius: 12px; }
    .sc-tag.blue { background: var(--blue-light); color: var(--blue); }
    .sc-tag.orange { background: var(--orange-bg); color: #c2410c; }
    .sc-tag.green { background: var(--green-bg); color: var(--green); }
    .sc-tag.purple { background: var(--purple-bg); color: var(--purple); }

    /* SHOP TYPE TABLE */
    .shop-table-wrap { background: #fff; border: 1px solid var(--gray-200); border-radius: 12px; overflow: hidden; overflow-x: auto; margin-bottom: 16px; }
    .shop-table { width: 100%; border-collapse: collapse; }
    .shop-table th { background: var(--gray-900); color: #fff; padding: 11px 16px; text-align: left; font-size: 12px; font-weight: 600; }
    .shop-table td { padding: 12px 16px; border-bottom: 1px solid var(--gray-100); font-size: 12.5px; vertical-align: top; }
    .shop-table tr:last-child td { border-bottom: none; }
    .shop-table tr:hover td { background: var(--gray-50); }
    .shop-type-badge { display: inline-block; font-size: 11px; font-weight: 700; padding: 3px 9px; border-radius: 6px; }
    .shop-type-badge.dautru { background: #fef9c3; color: #713f12; }
    .shop-type-badge.sieuxuong { background: var(--orange-bg); color: #c2410c; }
    .shop-type-badge.thuong { background: var(--gray-100); color: var(--gray-600); }

    /* PLATFORM CARDS */
    .platform-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 12px; }
    .platform-card { background: #fff; border: 1px solid var(--gray-200); border-radius: 10px; padding: 16px; text-align: center; }
    .platform-card .pc-icon { font-size: 32px; margin-bottom: 8px; }
    .platform-card h4 { font-size: 13px; font-weight: 700; color: var(--gray-900); margin-bottom: 4px; }
    .platform-card p  { font-size: 11.5px; color: var(--gray-600); }

    /* VIDEO GRID */
    .video-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(290px, 1fr)); gap: 16px; }
    .video-card { background: #fff; border: 1px solid var(--gray-200); border-radius: 12px; overflow: hidden; transition: box-shadow 0.2s, transform 0.15s; }
    .video-card:hover { box-shadow: 0 4px 16px rgba(0,0,0,0.1); transform: translateY(-2px); }
    .video-thumb { position: relative; padding-top: 56.25%; background: var(--gray-900); }
    .video-thumb iframe { position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: none; }
    .video-thumb .thumb-label { position: absolute; bottom: 8px; left: 10px; background: rgba(0,0,0,0.7); color: #fff; font-size: 10px; font-weight: 600; padding: 2px 8px; border-radius: 4px; }
    .video-info { padding: 14px 16px; }
    .video-info .ep { font-size: 11px; font-weight: 700; color: var(--blue); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px; }
    .video-info h4 { font-size: 13.5px; font-weight: 700; color: var(--gray-900); margin-bottom: 4px; line-height: 1.4; }
    .video-info p  { font-size: 12px; color: var(--gray-600); line-height: 1.5; }
    .video-info .vid-meta { display: flex; gap: 12px; margin-top: 10px; }
    .video-info .vid-meta span { font-size: 11px; color: var(--gray-400); }
    .video-link { display: block; text-align: center; padding: 10px; background: var(--blue-light); color: var(--blue); font-size: 12.5px; font-weight: 600; text-decoration: none; border-top: 1px solid var(--gray-100); transition: background 0.2s; }
    .video-link:hover { background: var(--blue); color: #fff; }

    /* FAQ */
    .faq-item { background: #fff; border: 1px solid var(--gray-200); border-radius: 10px; overflow: hidden; margin-bottom: 8px; }
    .faq-q { display: flex; align-items: flex-start; gap: 10px; padding: 14px 16px; cursor: pointer; font-size: 13.5px; font-weight: 600; color: var(--gray-900); transition: background 0.15s; }
    .faq-q:hover { background: var(--gray-50); }
    .faq-q .fq-num { background: var(--blue); color: #fff; font-size: 11px; font-weight: 700; padding: 2px 7px; border-radius: 4px; flex-shrink: 0; margin-top: 1px; }
    .faq-q .fq-arrow { margin-left: auto; color: var(--gray-400); font-size: 13px; transition: transform 0.2s; flex-shrink: 0; }
    .faq-a { padding: 0 16px 14px 42px; font-size: 13px; color: var(--gray-600); line-height: 1.7; display: none; }
    .faq-a.open { display: block; }
    .faq-a strong { color: var(--blue); }

    /* COMMUNITY TABLE */
    .community-table-wrap { background: #fff; border: 1px solid var(--gray-200); border-radius: 12px; overflow: hidden; overflow-x: auto; }
    .community-table { width: 100%; border-collapse: collapse; }
    .community-table th { background: var(--blue); color: #fff; padding: 10px 16px; text-align: left; font-size: 12px; font-weight: 600; }
    .community-table td { padding: 11px 16px; border-bottom: 1px solid var(--gray-100); font-size: 12.5px; }
    .community-table tr:last-child td { border-bottom: none; }
    .community-table tr:hover td { background: var(--gray-50); }
    .mem-badge { display: inline-block; background: var(--green-bg); color: var(--green); font-size: 11px; font-weight: 700; padding: 2px 9px; border-radius: 12px; }

    /* HIGHLIGHT BOX */
    .highlight-box { background: var(--yellow-bg); border: 1px solid #fde68a; border-radius: 10px; padding: 16px 20px; margin-bottom: 16px; }
    .highlight-box h4 { font-size: 13px; font-weight: 700; color: #713f12; margin-bottom: 8px; }
    .highlight-box p  { font-size: 12.5px; color: #92400e; line-height: 1.6; }
    .highlight-box ul { list-style: none; margin-top: 8px; }
    .highlight-box ul li { font-size: 12.5px; color: #92400e; margin-bottom: 5px; padding-left: 14px; position: relative; }
    .highlight-box ul li::before { content: '›'; position: absolute; left: 0; font-weight: 700; }

    /* PAGE FOOTER */
    .page-footer { text-align: center; padding-top: 32px; border-top: 1px solid var(--gray-200); margin-top: 20px; }
    .nav-btns { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; gap: 12px; flex-wrap: wrap; }
    .btn-nav { display: inline-flex; align-items: center; gap: 8px; padding: 10px 20px; border-radius: 8px; font-size: 13px; font-weight: 600; text-decoration: none; transition: background 0.2s; }
    .btn-nav.prev { background: var(--gray-100); color: var(--gray-700); }
    .btn-nav.prev:hover { background: var(--gray-200); }
    .btn-nav.next { background: var(--blue); color: #fff; }
    .btn-nav.next:hover { background: var(--blue-dark); }

    /* MOBILE */
    @media (max-width: 768px) {
      .menu-toggle { display: block; }
      .sidebar { transform: translateX(-100%); }
      .sidebar.open { transform: translateX(0); }
      .overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 99; }
      .overlay.visible { display: block; }
      .main { margin-left: 0; padding: 20px 16px 48px; }
      .module-hero { flex-direction: column; padding: 20px; }
      .progress-hero-wrap { display: flex; align-items: center; gap: 12px; }
    }
  
    /* ── SIDEBAR DROPDOWN TOGGLE ── */
    .nav-section-label{cursor:pointer;user-select:none;display:flex!important;align-items:center}
    .nav-arrow{margin-left:auto;font-size:9px;opacity:.45;transition:transform .3s ease;display:inline-block;flex-shrink:0;line-height:1;pointer-events:none}
    .nav-section-body{overflow:hidden;transition:max-height .3s ease}
    .nav-sub{overflow:hidden;transition:max-height .3s ease}
  </style>
</head>
