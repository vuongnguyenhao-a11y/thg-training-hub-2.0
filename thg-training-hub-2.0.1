    .topbar-left{display:flex;align-items:center;gap:12px}
    .menu-toggle{display:none;background:none;border:none;color:#fff;font-size:20px;cursor:pointer}
    .topbar-logo .badge{background:var(--orange);color:#fff;font-size:10px;font-weight:700;letter-spacing:1px;text-transform:uppercase;padding:2px 7px;border-radius:4px}
    .topbar-logo{display:flex;align-items:center;gap:8px}
    .topbar-logo span{color:#fff;font-size:15px;font-weight:700}
    .user-pill{display:flex;align-items:center;gap:8px;background:rgba(255,255,255,.12);border-radius:20px;padding:4px 12px 4px 6px}
    .user-pill .avatar{width:26px;height:26px;border-radius:50%;background:var(--sky);color:#fff;font-size:11px;font-weight:700;display:flex;align-items:center;justify-content:center}
    .user-pill span{color:rgba(255,255,255,.85);font-size:12px}

    .sidebar{position:fixed;top:var(--header-h);left:0;bottom:0;width:var(--sidebar-w);background:#fff;border-right:1px solid var(--gray-200);overflow-y:auto;z-index:100;transition:transform .25s ease}
    .sidebar::-webkit-scrollbar{width:4px}
    .sidebar::-webkit-scrollbar-thumb{background:var(--gray-200);border-radius:4px}
    .nav-section{padding:16px 0 4px}
    .nav-section-label{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1.2px;color:var(--gray-400);padding:0 16px 6px}
    .nav-item{display:flex;align-items:center;gap:10px;padding:9px 16px;text-decoration:none;color:var(--gray-700);font-size:13.5px;font-weight:500;transition:background .15s;position:relative}
    .nav-item:hover{background:var(--gray-50)}
    .nav-item.active{background:var(--sky-bg);color:var(--sky);font-weight:600}
    .nav-item.active::before{content:'';position:absolute;left:0;top:4px;bottom:4px;width:3px;background:var(--sky);border-radius:0 3px 3px 0}
    .nav-item .nav-icon{font-size:16px;flex-shrink:0;width:20px;text-align:center}
    .nav-badge{margin-left:auto;background:var(--orange);color:#fff;font-size:10px;font-weight:700;padding:1px 6px;border-radius:10px}
    .nav-badge.blue{background:var(--blue)} .nav-badge.green{background:var(--green)} .nav-badge.red{background:var(--red)}
    .nav-divider{height:1px;background:var(--gray-100);margin:8px 16px}
    .topic-nav-item{display:flex;align-items:center;gap:8px;padding:7px 16px 7px 32px;font-size:12.5px;color:var(--gray-600);text-decoration:none;transition:color .15s,background .15s}
    .topic-nav-item:hover{background:var(--gray-50);color:var(--sky)}
    .topic-nav-item.current{color:var(--sky);font-weight:600}
    .topic-num{font-size:10px;font-weight:700;background:var(--gray-200);color:var(--gray-600);padding:1px 6px;border-radius:10px;flex-shrink:0}
    .topic-nav-item.current .topic-num{background:var(--sky-bg);color:var(--sky)}

    .main{margin-left:var(--sidebar-w);margin-top:var(--header-h);min-height:calc(100vh - var(--header-h));padding:28px 32px 64px}
    .breadcrumb{display:flex;align-items:center;gap:6px;font-size:12.5px;color:var(--gray-400);margin-bottom:20px}
    .breadcrumb a{color:var(--blue);text-decoration:none}
    .breadcrumb a:hover{text-decoration:underline}

    /* HERO */
    .module-hero{background:linear-gradient(135deg,var(--sky-bg) 0%,#e0f2fe 100%);border:1px solid #bae6fd;border-radius:16px;padding:28px 32px;margin-bottom:28px;display:flex;align-items:flex-start;gap:24px}
    .module-hero-icon{font-size:52px;flex-shrink:0}
    .module-hero-body .tag{display:inline-block;background:var(--sky);color:#fff;font-size:11px;font-weight:700;padding:3px 10px;border-radius:4px;margin-bottom:10px;letter-spacing:.5px}
    .module-hero-body h1{font-size:22px;font-weight:800;color:var(--gray-900);margin-bottom:8px}
    .module-hero-body p{font-size:13.5px;color:var(--gray-600);max-width:620px}
    .module-meta-row{display:flex;gap:20px;margin-top:16px;flex-wrap:wrap}
    .meta-item{font-size:12px;color:var(--gray-600)}
    .meta-item strong{color:var(--gray-900)}
    .hero-ring{flex-shrink:0}
    .hero-ring svg{width:80px;height:80px}

    /* QUICK NAV */
    .module-progress-nav{background:#fff;border:1px solid var(--gray-200);border-radius:12px;padding:14px 20px;margin-bottom:28px;display:flex;gap:8px;flex-wrap:wrap;align-items:center}
    .mpn-label{font-size:12px;font-weight:600;color:var(--gray-400);margin-right:4px}
    .mpn-item{padding:5px 12px;border-radius:20px;font-size:12px;font-weight:600;text-decoration:none;transition:background .15s,color .15s;border:1.5px solid var(--gray-200);color:var(--gray-600);background:var(--gray-50)}
    .mpn-item:hover{border-color:var(--sky);color:var(--sky)}

    .content-section{margin-bottom:36px;scroll-margin-top:calc(var(--header-h) + 16px)}
    .section-hd{display:flex;align-items:center;gap:10px;margin-bottom:16px;padding-bottom:10px;border-bottom:2px solid var(--gray-100)}
    .section-hd .topic-badge{background:var(--sky);color:#fff;font-size:10px;font-weight:700;padding:3px 9px;border-radius:6px;letter-spacing:.5px;flex-shrink:0}
    .section-hd .topic-badge.red{background:var(--red)}
    .section-hd .topic-badge.green{background:var(--green)}
    .section-hd .topic-badge.orange{background:var(--orange)}
    .section-hd h2{font-size:16px;font-weight:700;color:var(--gray-900)}

    .note{border-radius:10px;padding:14px 16px;margin-bottom:14px;display:flex;gap:10px}
    .note.info  {background:var(--sky-bg);border-left:3px solid var(--sky)}
    .note.warn  {background:var(--yellow-bg);border-left:3px solid var(--yellow)}
    .note.danger{background:var(--red-bg);border-left:3px solid var(--red)}
    .note.success{background:var(--green-bg);border-left:3px solid var(--green)}
    .note.tip   {background:var(--blue-light);border-left:3px solid var(--blue)}
    .note .ni{font-size:16px;flex-shrink:0;margin-top:1px}
    .note .nt{font-size:13px;color:var(--gray-700)}
    .note .nt strong{color:var(--gray-900)}

    .tbl-wrap{overflow-x:auto;margin-bottom:16px}
    table{width:100%;border-collapse:collapse;font-size:13px}
    thead th{background:var(--sky);color:#fff;padding:9px 12px;text-align:left;font-weight:600;font-size:12px}
    thead th.blue-hd{background:var(--blue)}
    tbody td{padding:9px 12px;border-bottom:1px solid var(--gray-100);vertical-align:top}
    tbody tr:last-child td{border-bottom:none}
    tbody tr:nth-child(even){background:var(--gray-50)}
    .tbl-badge{display:inline-block;font-size:11px;font-weight:700;padding:2px 8px;border-radius:10px}
    .tbl-badge.sky   {background:var(--sky-bg);color:var(--sky)}
    .tbl-badge.blue  {background:var(--blue-light);color:var(--blue)}
    .tbl-badge.green {background:var(--green-bg);color:var(--green)}
    .tbl-badge.red   {background:var(--red-bg);color:var(--red)}
    .tbl-badge.orange{background:var(--orange-bg);color:var(--orange)}
    .tbl-badge.yellow{background:var(--yellow-bg);color:var(--yellow)}

    /* HIGHLIGHT BOXES */
    .highlight-row{display:flex;gap:12px;margin-bottom:16px;flex-wrap:wrap}
    .hl-box{flex:1;min-width:120px;background:#fff;border:1px solid var(--gray-200);border-radius:10px;padding:14px 16px;text-align:center}
    .hl-box .hl-val{font-size:22px;font-weight:800;color:var(--sky)}
