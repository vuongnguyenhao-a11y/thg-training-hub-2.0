    .step-body h4{font-size:13.5px;font-weight:700;color:var(--gray-900);margin-bottom:6px}
    .step-body ul{list-style:none}
    .step-body ul li{font-size:12.5px;color:var(--gray-600);margin-bottom:5px;padding-left:14px;position:relative;line-height:1.5}
    .step-body ul li::before{content:'·';position:absolute;left:0;color:var(--orange);font-weight:900;font-size:16px;line-height:1}
    .step-body .step-note{margin-top:8px;background:#fff;border:1px solid var(--gray-200);border-radius:6px;padding:8px 12px;font-size:12px;color:var(--gray-600)}

    /* RESPONSIBILITY MATRIX */
    .matrix-wrap{background:#fff;border:1px solid var(--gray-200);border-radius:12px;overflow:hidden;overflow-x:auto;margin-bottom:16px}
    .matrix-table{width:100%;border-collapse:collapse}
    .matrix-table th{padding:10px 14px;text-align:left;font-size:11.5px;font-weight:600;text-transform:uppercase;letter-spacing:.4px;border-bottom:1px solid var(--gray-200)}
    .matrix-table th:first-child{background:var(--gray-50);color:var(--gray-600);width:35%}
    .matrix-table th.sale{background:#f3e8ff;color:var(--purple)}
    .matrix-table th.cskh{background:var(--orange-bg);color:#c2410c}
    .matrix-table th.ops{background:var(--blue-light);color:var(--blue)}
    .matrix-table th.acct{background:var(--green-bg);color:var(--green)}
    .matrix-table td{padding:10px 14px;border-bottom:1px solid var(--gray-100);font-size:12.5px;vertical-align:middle;text-align:center}
    .matrix-table td:first-child{text-align:left;font-weight:500;color:var(--gray-700)}
    .matrix-table tr:last-child td{border-bottom:none}
    .matrix-table tr:hover td{background:var(--gray-50)}
    .r-primary{font-size:16px} .r-support{font-size:14px;opacity:.6} .r-none{color:var(--gray-200)}

    /* POLICY ACCORDION */
    .policy-block{background:#fff;border:1px solid var(--gray-200);border-radius:10px;overflow:hidden;margin-bottom:8px}
    .policy-header{display:flex;align-items:center;gap:10px;padding:13px 16px;cursor:pointer;background:var(--gray-50);border-bottom:1px solid var(--gray-200);user-select:none;transition:background .15s}
    .policy-header:hover{background:var(--gray-100)}
    .ph-id{font-size:10px;font-weight:700;padding:2px 8px;border-radius:4px;flex-shrink:0}
    .ph-id.orange{background:var(--orange);color:#fff}
    .ph-id.red{background:var(--red);color:#fff}
    .ph-id.blue{background:var(--blue);color:#fff}
    .ph-id.green{background:var(--green);color:#fff}
    .policy-header h3{font-size:13.5px;font-weight:700;color:var(--gray-900);flex:1}
    .policy-header .toggle{font-size:13px;color:var(--gray-400);transition:transform .2s}
    .policy-body{padding:16px 18px;font-size:13px;color:var(--gray-600);line-height:1.7;display:none}
    .policy-body.open{display:block}
    .policy-body ul{list-style:disc;padding-left:20px;margin-top:6px}
    .policy-body ul li{margin-bottom:5px}
    .hl{background:var(--yellow-bg);border-left:3px solid var(--yellow);padding:10px 14px;border-radius:0 8px 8px 0;margin:10px 0;font-size:13px;color:#713f12}
    .ok{background:var(--green-bg);border-left:3px solid var(--green);padding:10px 14px;border-radius:0 8px 8px 0;margin:10px 0;font-size:13px;color:#14532d}
    .err{background:var(--red-bg);border-left:3px solid var(--red);padding:10px 14px;border-radius:0 8px 8px 0;margin:10px 0;font-size:13px;color:#991b1b}

    /* TIMELINE TABLE */
    .timeline-table-wrap{background:#fff;border:1px solid var(--gray-200);border-radius:12px;overflow:hidden;overflow-x:auto}
    .timeline-table{width:100%;border-collapse:collapse}
    .timeline-table th{background:var(--orange);color:#fff;padding:10px 16px;text-align:left;font-size:12px;font-weight:600}
    .timeline-table td{padding:11px 16px;border-bottom:1px solid var(--gray-100);font-size:12.5px;vertical-align:top}
    .timeline-table tr:last-child td{border-bottom:none}
    .timeline-table tr:hover td{background:var(--gray-50)}
    .tl-badge{display:inline-block;font-size:11px;font-weight:700;padding:2px 9px;border-radius:6px}
    .tl-badge.fast {background:var(--green-bg);color:var(--green)}
    .tl-badge.slow {background:var(--yellow-bg);color:var(--yellow)}
    .tl-badge.urgent{background:var(--red-bg);color:var(--red)}

    /* SCRIPT BLOCK */
    .script-block{background:#fff;border:1.5px solid var(--gray-200);border-radius:10px;overflow:hidden;margin-bottom:12px}
    .script-header{background:var(--gray-900);padding:10px 16px;display:flex;align-items:center;gap:10px}
    .script-header .sh-tag{font-size:10px;font-weight:700;padding:2px 8px;border-radius:4px;background:var(--orange);color:#fff}
    .script-header .sh-title{font-size:12.5px;font-weight:600;color:rgba(255,255,255,.85)}
    .script-body{padding:14px 18px;font-size:13px;color:var(--gray-700);line-height:1.8;background:var(--gray-50);font-style:italic}
    .script-body strong{font-style:normal;color:var(--gray-900)}
    .script-body .placeholder{color:var(--orange);font-weight:600;font-style:normal}

    /* ESCALATION FLOW */
    .escalation-wrap{display:flex;flex-direction:column;gap:2px}
    .esc-level{display:flex;align-items:stretch;gap:0;border-radius:10px;overflow:hidden;border:1px solid var(--gray-200);margin-bottom:10px}
    .esc-level-num{padding:16px 14px;display:flex;align-items:center;justify-content:center;font-size:18px;font-weight:900;color:#fff;flex-shrink:0;min-width:48px}
    .esc-level-num.l1{background:var(--green)}
    .esc-level-num.l2{background:var(--yellow)}
    .esc-level-num.l3{background:var(--orange)}
    .esc-level-num.l4{background:var(--red)}
    .esc-content{padding:14px 18px;flex:1;background:#fff}
    .esc-content h4{font-size:13px;font-weight:700;color:var(--gray-900);margin-bottom:4px}
    .esc-content p{font-size:12.5px;color:var(--gray-600);line-height:1.5}
    .esc-content .esc-time{display:inline-block;font-size:11px;font-weight:600;background:var(--gray-100);color:var(--gray-600);padding:2px 8px;border-radius:10px;margin-top:6px}

    /* LARK GUIDE */
    .lark-steps{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:12px}
    .lark-step{background:#fff;border:1px solid var(--gray-200);border-radius:10px;padding:16px;display:flex;gap:12px}
    .lark-step .ls-num{width:28px;height:28px;border-radius:50%;background:var(--blue);color:#fff;font-size:12px;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px}
    .lark-step h4{font-size:13px;font-weight:700;color:var(--gray-900);margin-bottom:4px}
    .lark-step p{font-size:12px;color:var(--gray-600);line-height:1.5}

    /* PAGE FOOTER */
    .page-footer{text-align:center;padding-top:32px;border-top:1px solid var(--gray-200);margin-top:20px}
    .nav-btns{display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;gap:12px;flex-wrap:wrap}
    .btn-nav{display:inline-flex;align-items:center;gap:8px;padding:10px 20px;border-radius:8px;font-size:13px;font-weight:600;text-decoration:none;transition:background .2s}
    .btn-nav.prev{background:var(--gray-100);color:var(--gray-700)}
    .btn-nav.prev:hover{background:var(--gray-200)}
    .btn-nav.next{background:var(--orange);color:#fff}
    .btn-nav.next:hover{background:#ea6b0f}

    /* MOBILE */
    @media(max-width:768px){
      .menu-toggle{display:block}
      .sidebar{transform:translateX(-100%)}
      .sidebar.open{transform:translateX(0)}
      .overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.4);z-index:99}
      .overlay.visible{display:block}
      .main{margin-left:0;padding:20px 16px 48px}
      .module-hero{flex-direction:column;padding:20px}
      .sop-meta{display:none}
    }
  
    /* ── SIDEBAR DROPDOWN TOGGLE ── */
    .nav-section-label{cursor:pointer;user-select:none;display:flex!important;align-items:center}
    .nav-arrow{margin-left:auto;font-size:9px;opacity:.45;transition:transform .3s ease;display:inline-block;flex-shrink:0;line-height:1;pointer-events:none}
    .nav-section-body{overflow:hidden;transition:max-height .3s ease}
    .nav-sub{overflow:hidden;transition:max-height .3s ease}
  </style>
</head>
