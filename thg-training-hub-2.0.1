.card-sev{font-size:.75rem;font-weight:600;padding:3px 10px;border-radius:12px;flex-shrink:0}
.card-sev.critical{background:var(--critical-bg);color:var(--critical)}
.card-sev.warning{background:var(--warning-bg);color:#b45309}
.card-sev.minor{background:var(--minor-bg);color:#15803d}
.card-chevron{font-size:.8rem;color:#94a3b8;transition:transform .2s;flex-shrink:0}
.card-body{display:none;padding:0 20px 20px;border-top:1px solid #f1f5f9}
.card-body.open{display:block}
/* CARD BODY GRID */
.info-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-top:16px}
.info-block{background:#f8fafc;border-radius:8px;padding:14px}
.info-block.full{grid-column:1/-1}
.info-block label{display:block;font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:#64748b;margin-bottom:6px}
.info-block p,.info-block ul{font-size:.875rem;color:#334155;line-height:1.6}
.info-block ul{padding-left:16px}
.info-block ul li{margin-bottom:3px}
/* SOLUTION STEPS */
.steps{counter-reset:step;margin-top:8px}
.step-item{display:flex;gap:10px;margin-bottom:10px;font-size:.875rem;color:#334155;line-height:1.5}
.step-num{background:var(--blue);color:#fff;border-radius:50%;min-width:22px;height:22px;display:flex;align-items:center;justify-content:center;font-size:.72rem;font-weight:700;flex-shrink:0;margin-top:1px}
/* META ROW */
.meta-row{display:flex;gap:20px;margin-top:14px;flex-wrap:wrap}
.meta-pill{display:flex;align-items:center;gap:6px;background:#f1f5f9;border-radius:8px;padding:6px 12px;font-size:.8rem}
