    .video-card{background:#fff;border:1px solid var(--gray-200);border-radius:12px;overflow:hidden}
    .video-wrap{position:relative;padding-bottom:56.25%;background:#000;border-radius:0}
    .video-wrap iframe{position:absolute;inset:0;width:100%;height:100%;border:none}
    .video-info{padding:12px 14px}
    .video-info h4{font-size:13px;font-weight:700;color:var(--gray-900);margin-bottom:4px}
    .video-info p{font-size:12px;color:var(--gray-600)}

    .group-list{display:flex;flex-direction:column;gap:10px;margin-bottom:16px}
    .group-item{background:#fff;border:1px solid var(--gray-200);border-radius:10px;padding:14px 16px;display:flex;align-items:center;gap:14px}
    .group-icon{font-size:22px;flex-shrink:0}
    .group-body{flex:1}
    .group-body h4{font-size:13.5px;font-weight:700;color:var(--gray-900)}
    .group-body p{font-size:12px;color:var(--gray-600)}
    .group-badge{font-size:11px;font-weight:700;padding:3px 10px;border-radius:10px;background:var(--green-bg);color:var(--green);white-space:nowrap}

    .checklist{display:flex;flex-direction:column;gap:6px;margin-bottom:12px}
    .checklist-item{display:flex;align-items:flex-start;gap:10px;padding:10px 14px;background:#fff;border:1px solid var(--gray-200);border-radius:8px;font-size:13px;color:var(--gray-700);cursor:pointer;transition:background .15s}
    .checklist-item:hover{background:var(--gray-50)}
    .checklist-item input[type=checkbox]{width:16px;height:16px;accent-color:var(--orange);flex-shrink:0;margin-top:1px;cursor:pointer}
    .checklist-item.done{background:var(--green-bg);border-color:#86efac}
    .checklist-item.done label{color:var(--green);text-decoration:line-through}

    .accordion{border:1px solid var(--gray-200);border-radius:10px;overflow:hidden;margin-bottom:12px}
    .accordion-hd{background:#fff;padding:14px 16px;cursor:pointer;display:flex;align-items:center;justify-content:space-between;font-size:13.5px;font-weight:600;color:var(--gray-900);transition:background .15s;user-select:none}
    .accordion-hd:hover{background:var(--gray-50)}
    .accordion-hd .acc-icon{font-size:12px;color:var(--gray-400);transition:transform .25s}
    .accordion-hd.open .acc-icon{transform:rotate(180deg)}
    .accordion-body{display:none;padding:16px;background:#fff;border-top:1px solid var(--gray-100);font-size:13px;color:var(--gray-700);line-height:1.7}
    .accordion-body ul{padding-left:16px}
    .accordion-body ul li{margin-bottom:5px}
    .accordion-body p{margin-bottom:8px}

    .highlight-row{display:flex;gap:12px;margin-bottom:16px;flex-wrap:wrap}
    .hl-box{flex:1;min-width:130px;background:#fff;border:1px solid var(--gray-200);border-radius:10px;padding:14px 16px;text-align:center}
    .hl-box .hl-val{font-size:22px;font-weight:800;color:var(--orange)}
    .hl-box .hl-val.blue{color:var(--blue)}
    .hl-box .hl-label{font-size:11.5px;color:var(--gray-600);margin-top:2px}

    .two-col{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px}
    .col-block{background:#fff;border:1px solid var(--gray-200);border-radius:10px;padding:16px}
    .col-block h4{font-size:13px;font-weight:700;color:var(--gray-900);margin-bottom:10px;display:flex;align-items:center;gap:6px}
    .col-block ul{padding-left:16px}
    .col-block ul li{font-size:13px;color:var(--gray-600);margin-bottom:4px}

    .overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.4);z-index:90}
    .overlay.show{display:block}

    @media(max-width:768px){
      .menu-toggle{display:block}
      .sidebar{transform:translateX(-100%)}
      .sidebar.open{transform:translateX(0)}
      .main{margin-left:0;padding:20px 16px 64px}
      .module-hero{flex-direction:column;gap:12px}
      .two-col{grid-template-columns:1fr}
      .video-grid{grid-template-columns:1fr}
    }
  
    /* ── SIDEBAR DROPDOWN TOGGLE ── */
