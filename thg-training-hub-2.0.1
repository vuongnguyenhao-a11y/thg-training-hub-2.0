<style>
:root{--blue:#1B4FBB;--orange:#F97316;--critical:#ef4444;--critical-bg:#fef2f2;--warning:#f59e0b;--warning-bg:#fffbeb;--minor:#22c55e;--minor-bg:#f0fdf4;--sidebar:260px;--top:56px}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:#f8fafc;color:#1e293b}
/* TOPBAR */
.topbar{position:fixed;top:0;left:0;right:0;height:var(--top);background:var(--blue);display:flex;align-items:center;padding:0 20px;z-index:100;gap:12px}
.topbar .logo{color:#fff;font-weight:700;font-size:1.1rem;text-decoration:none}
