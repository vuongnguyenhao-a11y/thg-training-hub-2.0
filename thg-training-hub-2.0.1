  </div>

  <!-- ── T3: QUY TRÌNH TQ → USA ── -->
  <div class="content-section" id="topic3">
    <div class="section-hd"><span class="topic-badge">TOPIC 3</span><h2>Quy Trình Fulfill từ Trung Quốc → USA & EU</h2></div>

    <div class="process-flow">
      <div class="pf-step"><div class="pf-box highlight"><div class="pf-icon">🔍</div><div class="pf-label">Tìm kiếm hàng</div></div></div>
