    .wh-detail .wd-label { font-size: 11px; font-weight: 700; color: var(--gray-400); text-transform: uppercase; letter-spacing: 0.5px; min-width: 56px; flex-shrink: 0; padding-top: 1px; }
    .wh-detail .wd-value { font-size: 12.5px; color: var(--gray-700); font-family: monospace; background: var(--gray-50); padding: 3px 10px; border-radius: 6px; }

    /* ── COMPETITOR LIST ── */
    .competitor-list { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 10px; }
    .comp-item { background: #fff; border: 1px solid var(--gray-200); border-radius: 10px; padding: 14px 16px; display: flex; align-items: center; gap: 10px; }
    .comp-item .comp-icon { font-size: 20px; }
    .comp-item span { font-size: 13px; font-weight: 600; color: var(--gray-700); }

    /* ── UPDATE CARD ── */
    .update-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 12px; }
    .update-item { background: #fff; border: 1px solid var(--gray-200); border-radius: 10px; padding: 16px; display: flex; gap: 12px; }
    .update-item .ui-num { font-size: 22px; font-weight: 900; color: var(--orange); opacity: 0.3; line-height: 1; flex-shrink: 0; min-width: 24px; }
